---
// src/components/NewsFeed.astro
// Fetches RSS feeds from trusted security news sources and displays the latest items.
// NOTE: Requires the `rss-parser` package (already listed in package.json).
// This component runs at build time (SSG). If a feed is unavailable, it is skipped
// gracefully and an informational message is shown when no items are found.

import Parser from 'rss-parser';

const FEEDS = [
  { name: 'BleepingComputer',  url: 'https://www.bleepingcomputer.com/feed/' },
  { name: 'The Hacker News',   url: 'https://feeds.feedburner.com/TheHackersNews' },
  { name: 'PortSwigger',       url: 'https://portswigger.net/daily-swig/rss' },
];

const MAX_PER_SOURCE = 5;
const MAX_TOTAL      = 10;
const DAYS_WINDOW    = 7;
const cutoff         = Date.now() - DAYS_WINDOW * 24 * 60 * 60 * 1000;

interface FeedItem {
  title:   string;
  link:    string;
  source:  string;
  pubDate: Date;
}

const parser = new Parser();
let items: FeedItem[] = [];
let fetchError = false;

// Fetch all feeds in parallel; skip any that fail
const results = await Promise.allSettled(
  FEEDS.map(async (feed) => {
    const parsed = await parser.parseURL(feed.url);
    return parsed.items.slice(0, MAX_PER_SOURCE).map((item) => ({
      title:   item.title  ?? '(no title)',
      link:    item.link   ?? '#',
      source:  feed.name,
      pubDate: new Date(item.pubDate ?? item.isoDate ?? Date.now()),
    }));
  })
);

for (const result of results) {
  if (result.status === 'fulfilled') {
    items.push(...result.value);
  } else {
    // At least one feed failed – flag it so we can show a notice
    fetchError = true;
  }
}

// Filter to last 7 days, sort newest first, keep top 10
items = items
  .filter((i) => i.pubDate.getTime() >= cutoff)
  .sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime())
  .slice(0, MAX_TOTAL);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<section class="news-feed">
  <h2 class="feed-heading">Security News</h2>

  {fetchError && (
    <p class="feed-notice">⚠️ Some news sources could not be reached right now.</p>
  )}

  {items.length === 0 ? (
    <p class="feed-empty">No recent security news found. Check back soon!</p>
  ) : (
    <ul class="feed-list">
      {items.map((item) => (
        <li class="feed-item">
          <a class="feed-title" href={item.link} target="_blank" rel="noopener noreferrer">
            {item.title}
          </a>
          <span class="feed-meta">
            <span class="feed-source">{item.source}</span>
            &middot;
            <time datetime={item.pubDate.toISOString()}>{formatDate(item.pubDate)}</time>
          </span>
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .news-feed {
    background: #FFFBF0;
    border: 1px solid #E8D8B0;
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2.5rem;
    box-shadow: 0 2px 12px rgba(204, 133, 0, 0.08);
  }

  .feed-heading {
    font-size: 1.3rem;
    color: #CC8500;
    margin-bottom: 1rem;
    border-bottom: 2px solid #E8D8B0;
    padding-bottom: 0.5rem;
  }

  .feed-notice,
  .feed-empty {
    color: #888;
    font-style: italic;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
  }

  .feed-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .feed-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 1rem;
    background: #fff;
    border: 1px solid #E8D8B0;
    border-radius: 8px;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .feed-item:hover {
    box-shadow: 0 4px 16px rgba(255, 140, 66, 0.18);
    border-color: #FF8C42;
  }

  .feed-title {
    font-weight: 600;
    color: #333;
    text-decoration: none;
    font-size: 0.97rem;
    line-height: 1.4;
  }

  .feed-title:hover {
    color: #FF8C42;
    text-decoration: underline;
  }

  .feed-meta {
    font-size: 0.8rem;
    color: #888;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .feed-source {
    font-weight: 600;
    color: #CC8500;
  }
</style>
