---
// src/pages/index.astro
// Homepage – animated logo, welcome heading, auth buttons, and security news feed.
import Layout from '../layouts/Layout.astro';
import NewsFeed from '../components/NewsFeed.astro';
---

<Layout title="kyuby.com – Edge-first infrastructure">
  <div class="hero">
    <!-- Animated logo (tail wag applied to the <g> tail group via CSS) -->
    <div class="logo-wrapper">
      <svg
        width="220"
        height="220"
        viewBox="0 0 400 400"
        xmlns="http://www.w3.org/2000/svg"
        aria-label="kyuby mascot logo"
        role="img"
      >
        <rect width="400" height="400" fill="#FFF8E7" rx="20"/>
        <defs>
          <linearGradient id="tailGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#FF8C42"/>
            <stop offset="100%" stop-color="#FFD700"/>
          </linearGradient>
        </defs>

        <!-- Tail group – animated via .tail-group CSS class -->
        <g class="tail-group" fill="url(#tailGrad)" opacity="0.9">
          <path d="M200 230 L140 270 L160 220 Z" transform="rotate(-80,200,200)"/>
          <path d="M200 230 L130 260 L150 210 Z" transform="rotate(-60,200,200)"/>
          <path d="M200 230 L120 240 L140 190 Z" transform="rotate(-40,200,200)"/>
          <path d="M200 230 L110 220 L130 170 Z" transform="rotate(-20,200,200)"/>
          <path d="M200 230 L100 200 L120 150 Z" transform="rotate(0,200,200)"/>
          <path d="M200 230 L110 180 L130 130 Z" transform="rotate(20,200,200)"/>
          <path d="M200 230 L120 160 L140 110 Z" transform="rotate(40,200,200)"/>
          <path d="M200 230 L130 140 L150 90 Z" transform="rotate(60,200,200)"/>
          <path d="M200 230 L140 120 L160 70 Z" transform="rotate(80,200,200)"/>
        </g>

        <circle cx="200" cy="200" r="70" fill="#FF8C42" stroke="#CC8500" stroke-width="3"/>
        <polygon points="160,140 140,90 180,120" fill="#FF8C42" stroke="#CC8500" stroke-width="2"/>
        <polygon points="240,140 260,90 220,120" fill="#FF8C42" stroke="#CC8500" stroke-width="2"/>
        <polygon points="165,130 150,100 175,115" fill="#FFB347" opacity="0.8"/>
        <polygon points="235,130 250,100 225,115" fill="#FFB347" opacity="0.8"/>
        <circle cx="170" cy="200" r="10" fill="#333333"/>
        <circle cx="230" cy="200" r="10" fill="#333333"/>
        <circle cx="165" cy="195" r="3" fill="white"/>
        <circle cx="225" cy="195" r="3" fill="white"/>
        <polygon points="200,220 195,230 205,230" fill="#333333"/>
        <line x1="140" y1="210" x2="100" y2="205" stroke="#CC8500" stroke-width="2"/>
        <line x1="140" y1="220" x2="100" y2="225" stroke="#CC8500" stroke-width="2"/>
        <line x1="260" y1="210" x2="300" y2="205" stroke="#CC8500" stroke-width="2"/>
        <line x1="260" y1="220" x2="300" y2="225" stroke="#CC8500" stroke-width="2"/>
        <text x="120" y="350" font-family="'Quicksand','Arial Rounded',sans-serif" font-size="48" font-weight="600" fill="#333333" letter-spacing="2">kyuby</text>
        <text x="290" y="355" font-family="'Quicksand','Arial Rounded',sans-serif" font-size="24" fill="#999999">.com</text>
      </svg>
    </div>

    <h1 class="hero-title">Welcome to kyuby</h1>
    <p class="hero-sub">Edge&#8209;first infrastructure.</p>

    <!-- Auth buttons (non-functional placeholders) -->
    <div class="auth-buttons">
      <button class="btn btn-google" type="button">
        <i class="fab fa-google" aria-hidden="true"></i>
        Login with Google
      </button>
      <button class="btn btn-github" type="button">
        <i class="fab fa-github" aria-hidden="true"></i>
        Login with GitHub
      </button>
    </div>
  </div>

  <!-- Security news feed component -->
  <NewsFeed />
</Layout>

<style>
  /* ── Hero section ── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 0 1rem;
    gap: 0.75rem;
  }

  .logo-wrapper {
    filter: drop-shadow(0 4px 16px rgba(255, 140, 66, 0.25));
  }

  .hero-title {
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 700;
    color: #333;
    margin-top: 0.5rem;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: #888;
    letter-spacing: 0.02em;
  }

  /* ── Auth buttons ── */
  .auth-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border: 2px solid transparent;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
  }

  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
  }

  .btn-google {
    background: #fff;
    color: #333;
    border-color: #E8D8B0;
  }

  .btn-google:hover {
    background: #FFF8E7;
    border-color: #FF8C42;
    color: #FF8C42;
  }

  .btn-github {
    background: #333;
    color: #fff;
    border-color: #333;
  }

  .btn-github:hover {
    background: #111;
    border-color: #111;
  }

  /* ── Tail wag animation ── */
  @keyframes tailWag {
    0%   { transform: rotate(0deg); }
    50%  { transform: rotate(2deg); }
    100% { transform: rotate(0deg); }
  }

  .tail-group {
    animation: tailWag 3s ease-in-out infinite;
    transform-origin: center;
  }
</style>
